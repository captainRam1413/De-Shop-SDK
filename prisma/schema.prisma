// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Asset {
  id          String   @id @default(cuid())
  assetId     Int      @unique
  name        String
  description String   @default("")
  rarity      String   @default("common") // common, rare, epic, legendary
  type        String   @default("weapon") // weapon, character, accessory
  price       Float    @default(0)
  confidence  Float    @default(0)
  imageUrl    String   @default("")
  emoji       String   @default("📦")
  seller      String   @default("")
  owner       String   @default("")
  listed      Boolean  @default(false)
  mintedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  type        String   // mint, buy, sell, transfer, list, cancel
  assetId     Int
  assetName   String
  from        String   @default("")
  to          String   @default("")
  amount      Float    @default(0)
  status      String   @default("confirmed") // confirmed, pending, failed
  txHash      String   @default("")
  createdAt   DateTime @default(now())
}

model Plugin {
  id          String   @id @default(cuid())
  name        String
  description String
  version     String
  engine      String   // minecraft, unity, unreal, web
  language    String
  status      String   @default("stable") // stable, beta, alpha
  downloads   Int      @default(0)
  rating      Float    @default(0)
  fileUrl     String   @default("")
  sourceUrl   String   @default("")
  fileSize    String   @default("")
  checksum    String   @default("")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}